# Anthropic API key for AI analysis
ANTHROPIC_API_KEY=sk-ant-your-key-here

# AWS profile for S3 backups (uses system AWS credentials)
AWS_PROFILE=default

# S3 bucket for database backups
S3_BACKUP_BUCKET=your-bucket-name

# Database path (default: fathom/data/fathom.db relative to repo root)
# DB_PATH=/path/to/custom/fathom.db

# App host/port (defaults: 0.0.0.0:8000)
# HOST=0.0.0.0
# PORT=8000
